<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/bg_surface"
    android:padding="24dp">

    <!-- Handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:background="@color/border"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="20dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="CLIPBOARD EVENT DETAIL"
        android:textSize="13sp"
        android:textStyle="bold"
        android:textColor="@color/accent_cyan"
        android:fontFamily="monospace"
        android:letterSpacing="0.1"
        android:layout_marginBottom="16dp"/>

    <!-- Risk level -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Risk Level"
            android:textSize="13sp"
            android:textColor="@color/text_muted"/>
        <TextView
            android:id="@+id/tv_detail_risk"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/danger"/>
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/border" android:layout_marginBottom="12dp"/>

    <!-- App name -->
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="App" android:textSize="11sp" android:textColor="@color/text_muted" android:layout_marginBottom="2dp"/>
    <TextView android:id="@+id/tv_detail_app_name" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="14sp" android:textStyle="bold" android:textColor="@color/white" android:layout_marginBottom="12dp"/>

    <!-- Package -->
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Package" android:textSize="11sp" android:textColor="@color/text_muted" android:layout_marginBottom="2dp"/>
    <TextView android:id="@+id/tv_detail_package" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="12sp" android:textColor="@color/text_secondary" android:fontFamily="monospace" android:layout_marginBottom="12dp"/>

    <!-- Time -->
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Time" android:textSize="11sp" android:textColor="@color/text_muted" android:layout_marginBottom="2dp"/>
    <TextView android:id="@+id/tv_detail_time" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="12sp" android:textColor="@color/text_secondary" android:layout_marginBottom="12dp"/>

    <!-- Data Type -->
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Data Type Detected" android:textSize="11sp" android:textColor="@color/text_muted" android:layout_marginBottom="2dp"/>
    <TextView android:id="@+id/tv_detail_data_type" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="13sp" android:textColor="@color/accent_cyan" android:textStyle="bold" android:layout_marginBottom="12dp"/>

    <!-- Content length -->
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Content Length" android:textSize="11sp" android:textColor="@color/text_muted" android:layout_marginBottom="2dp"/>
    <TextView android:id="@+id/tv_detail_length" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="12sp" android:textColor="@color/text_secondary" android:layout_marginBottom="12dp"/>

    <!-- Preview -->
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Content Preview" android:textSize="11sp" android:textColor="@color/text_muted" android:layout_marginBottom="2dp"/>
    <TextView android:id="@+id/tv_detail_preview" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="12sp" android:textColor="@color/text_secondary" android:fontFamily="monospace" android:background="@color/bg_primary" android:padding="10dp" android:layout_marginBottom="12dp"/>

    <!-- Risk reason -->
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Risk Reason" android:textSize="11sp" android:textColor="@color/text_muted" android:layout_marginBottom="2dp"/>
    <TextView android:id="@+id/tv_detail_reason" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="12sp" android:textColor="@color/warning" android:layout_marginBottom="12dp"/>

    <!-- Content hash -->
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Content Hash (SHA-256)" android:textSize="11sp" android:textColor="@color/text_muted" android:layout_marginBottom="2dp"/>
    <TextView android:id="@+id/tv_detail_hash" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="11sp" android:textColor="@color/text_muted" android:fontFamily="monospace" android:layout_marginBottom="24dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_close"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Close"
        app:backgroundTint="@color/bg_primary"
        android:textColor="@color/text_muted"
        app:strokeColor="@color/border"
        app:strokeWidth="1dp"
        xmlns:app="http://schemas.android.com/apk/res-auto"/>

</LinearLayout>

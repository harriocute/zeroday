<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_primary"
    android:padding="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="AI SCANNER"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="@color/white"
        android:letterSpacing="0.1"
        android:layout_marginBottom="20dp" />

    <!-- Progress Group -->
    <LinearLayout
        android:id="@+id/progress_group"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        android:layout_marginBottom="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/tv_current_app"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="12sp"
                android:textColor="@color/accent_cyan"
                android:ellipsize="end"
                android:maxLines="1" />

            <TextView
                android:id="@+id/tv_scan_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="@color/text_muted" />
        </LinearLayout>

        <ProgressBar
            android:id="@+id/progress_bar"
            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="8dp"
            android:max="100"
            android:progressTint="@color/accent_cyan"
            android:progressBackgroundTint="@color/bg_surface"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tv_progress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0%"
            android:textSize="13sp"
            android:textColor="@color/accent_cyan"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Scan result summary -->
    <TextView
        android:id="@+id/tv_scan_result"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:textSize="13sp"
        android:textColor="@color/accent_green"
        android:background="@drawable/bg_badge_green"
        android:padding="12dp"
        android:layout_marginBottom="16dp" />

    <!-- Start scan button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_start_scan"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="START AI SCAN"
        android:textSize="14sp"
        android:letterSpacing="0.1"
        app:backgroundTint="@color/accent_cyan"
        android:textColor="@color/bg_primary"
        android:layout_marginBottom="20dp" />

    <!-- Results list -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="SCAN RESULTS"
        android:textSize="11sp"
        android:textColor="@color/text_muted"
        android:letterSpacing="0.2"
        android:layout_marginBottom="10dp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_threats"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false" />

</LinearLayout>
